# frontend/.env.local
# Copy this to .env.local and fill in values

# Backend API
NEXT_PUBLIC_API_URL=http://localhost:8081

# Soroban RPC endpoint (Stellar Testnet)
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Contract IDs (set after running: node scripts/deploy-contracts.mjs)
NEXT_PUBLIC_EQUIPMENTREGISTRY_ID=
NEXT_PUBLIC_MAINTENANCERECORDS_ID=
NEXT_PUBLIC_MULTIPARTYAPPROVAL_ID=
NEXT_PUBLIC_COMPLIANCEATTESTATION_ID=
