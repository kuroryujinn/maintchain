# frontend/.env.local
# Copy this to .env.local and fill in values
# For Vercel deployment: set these in Vercel Dashboard → Project Settings → Environment Variables

# Backend API (Render) — set to your deployed Render backend URL
NEXT_PUBLIC_API_URL=https://maintchain.onrender.com

# Soroban RPC endpoint (Stellar Testnet)
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# ── Deployed Soroban Contract IDs (Stellar Testnet) ──
# Deployed via: node scripts/deploy-contracts.mjs
# See README.md → "Testnet Contract Deployments" for deployment transactions
NEXT_PUBLIC_EQUIPMENT_REGISTRY_ID=CAT57KYD2WU5QMNBSGB4FJQ37JUUQRKFDMZVPTJZVFC2H44EKWKZWWEW
NEXT_PUBLIC_MAINTENANCE_RECORDS_ID=CBRIGG27YRAXG5H74ZOWSSJGMSTPQHZXJCDXA23QSSBIH6VYZZR4775Z
NEXT_PUBLIC_MULTI_PARTY_APPROVAL_ID=CBPHZFRYKSE6PUWHU2HSNQTWBQ47GYV3U73KXPSOPIX3QLQJ7MLSJOYH
NEXT_PUBLIC_COMPLIANCE_ATTESTATION_ID=CBR4HHPWRDXMJJOG65B6I5TRIBBUFAXAMUCTAJANAPBAIJHPKRUTCVIN

# ── Sentry Error Tracking ──
# Get your DSN from https://sentry.io (free tier available)
# For Vercel: set this in Vercel Dashboard → Environment Variables
NEXT_PUBLIC_SENTRY_DSN=
